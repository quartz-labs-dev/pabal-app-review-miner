{
  "name": "pabal-app-review-miner",
  "version": "1.0.0",
  "description": "CLI tool for collecting raw App Store and Google Play reviews by app.",
  "type": "commonjs",
  "bin": {
    "pabal-app-review-miner": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run dev:collect-reviews",
    "dev:collect-reviews": "tsx src/cli.ts",
    "dev:collect-reviews-by-name": "tsx src/addByName.ts",
    "dev:translate-reviews": "tsx src/translateReviews.ts",
    "dev:analyze-competitors": "tsx src/analyzeCompetitors.ts",
    "dev:render-report-html": "tsx src/renderReportHtml.ts",
    "precollect-reviews": "npm run build",
    "collect-reviews": "node dist/cli.js",
    "precollect-reviews-by-name": "npm run build",
    "collect-reviews-by-name": "node dist/addByName.js",
    "pretranslate-reviews": "npm run build",
    "translate-reviews": "node dist/translateReviews.js",
    "preanalyze-competitors": "npm run build",
    "analyze-competitors": "node dist/analyzeCompetitors.js",
    "prerender-report-html": "npm run build",
    "render-report-html": "node dist/renderReportHtml.js",
    "setup:config": "node scripts/setup-config.mjs",
    "start": "npm run collect-reviews"
  },
  "keywords": [
    "app-store",
    "google-play",
    "reviews",
    "review-mining"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "google-play-scraper": "^10.1.2",
    "node-fetch": "^3.3.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
